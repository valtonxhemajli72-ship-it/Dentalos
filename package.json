{
  "name": "dentalos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "auth:validate": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/validate-auth-rbac.mjs",
    "invitation:validate": "node scripts/validate-invitation-acceptance.mjs",
    "runtime:validate": "node scripts/validate-local-runtime.mjs",
    "bootstrap:admin": "node scripts/bootstrap-first-admin.mjs",
    "bootstrap:validate": "node scripts/validate-bootstrap-admin.mjs",
    "tenant:validate": "node scripts/validate-tenant-security.mjs",
    "rls:validate": "node scripts/validate-rls-readiness.mjs",
    "campaign:validate": "node scripts/validate-recall-campaigns.mjs",
    "dev:db": "docker compose up -d",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:validate": "node scripts/validate-prisma.mjs",
    "db:seed": "node scripts/seed-demo-data.mjs",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "8.5.14",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3"
  }
}
