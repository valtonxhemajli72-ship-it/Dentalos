# Local development PostgreSQL from docker-compose.yml.
DATABASE_URL="postgresql://dentalos:dentalos_dev_password@localhost:5432/klinika360_dev?schema=public"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="replace-with-secure-random-value"
NEXTAUTH_SECRET="replace-with-secure-random-value"

# Development only. Production ignores demo auth.
DEMO_AUTH_ENABLED="true"

# Optional real OAuth provider values for local Google sign-in testing.
AUTH_GOOGLE_ID="optional-placeholder"
AUTH_GOOGLE_SECRET="optional-placeholder"

# Optional future integration placeholders. Do not commit real values.
OPENAI_API_KEY="optional-placeholder-do-not-commit-real-key"
RESEND_API_KEY="optional-placeholder-do-not-commit-real-key"
TWILIO_ACCOUNT_SID="optional-placeholder-do-not-commit-real-key"
TWILIO_AUTH_TOKEN="optional-placeholder-do-not-commit-real-key"
